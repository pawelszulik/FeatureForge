<Window x:Class="FeatureForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FeatureForge.ViewModels"
        Title="{Binding SelectedProject.Name, StringFormat='{}{0} FeatureForge – Generator zadań zespołu'}"
        Height="750" Width="1100" MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Górny pasek: epic + tytuł + opis feature -->
        <Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="12,10">
            <StackPanel>
                <!-- Wiersz 1: epic, tytuł, przyciski -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Projekt -->
                    <ComboBox Grid.Column="0"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableProjects}"
                              SelectedItem="{Binding SelectedProject, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Name"
                              Padding="8,6"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              ToolTip="Wybierz projekt"/>

                    <!-- Epic -->
                    <ComboBox Grid.Column="1"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableModules}"
                              SelectedItem="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Text="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}"
                              Padding="8,6"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              ToolTip="Wybierz lub wpisz nazwę epica (rodzic Feature w TFS)"/>

                    <TextBox Grid.Column="2"
                             Text="{Binding FeatureTitle, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0"
                             Padding="8,6"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             ToolTip="Krótki tytuł feature'a (używany w TFS i nazwie folderu)"/>

                    <Button Grid.Column="3"
                            Content="Wywiad"
                            Command="{Binding InterviewCommand}"
                            Padding="14,6"
                            Margin="0,0,6,0"
                            FontSize="13"
                            Background="#6A1B9A" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Przeprowadź wywiad doprecyzowujący przed generacją"/>
                    <Button Grid.Column="4"
                            Content="Generuj wszystko"
                            Command="{Binding GenerateCommand}"
                            Padding="16,6"
                            Margin="0,0,6,0"
                            FontSize="13"
                            Background="#0078D4" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Grid.Column="5"
                            Content="Wczytaj"
                            Command="{Binding LoadCommand}"
                            Padding="12,6"
                            Margin="0,0,6,0"
                            FontSize="13"
                            Background="#555" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Grid.Column="6"
                            Content="Wyczyść"
                            Command="{Binding ClearCommand}"
                            Padding="12,6"
                            FontSize="13"
                            Background="#555" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>

                <!-- Wiersz 2: opis feature (wielowierszowy) -->
                <TextBox Text="{Binding FeatureText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         FontSize="13"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="Szczegółowy opis feature'a wysyłany do LLM"/>
            </StackPanel>
        </Border>

        <!-- Panel wyboru agentów do wywiadu -->
        <Border DockPanel.Dock="Top"
                Background="#1A0A2E"
                Padding="12,10"
                Visibility="{Binding IsAgentSelectionVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Wybierz role, które zadadzą pytania:"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#CE93D8"
                           Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding AgentInterviewSelections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"
                                      Foreground="#CCCCCC"
                                      FontSize="12"
                                      Margin="0,3"
                                      Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Rozpocznij wywiad"
                            Command="{Binding StartInterviewCommand}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="#6A1B9A" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"/>
                    <Button Content="Pomiń wywiad"
                            Command="{Binding CancelAgentSelectionCommand}"
                            Padding="14,6"
                            Background="#555" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Panel wywiadu -->
        <Border DockPanel.Dock="Top"
                Background="#1A0A2E"
                Padding="12,10"
                MaxHeight="320"
                Visibility="{Binding IsInterviewVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Pytania doprecyzowujące:"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#CE93D8"
                           Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                <ItemsControl ItemsSource="{Binding InterviewQuestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <!-- Nagłówek roli (widoczny gdy AgentName jest ustawione) -->
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#9C4DCC"
                                           Margin="0,6,0,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFirstInGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="▸ "/><Run Text="{Binding AgentName}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Question}"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"/>
                                <Grid>
                                    <TextBox Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8,5"
                                             FontSize="12"
                                             Background="#2D1B40"
                                             Foreground="#E1BEE7"
                                             BorderBrush="#6A1B9A"
                                             CaretBrush="White"/>
                                    <TextBlock Text="{Binding DefaultAnswer}"
                                               Foreground="#666"
                                               FontSize="12"
                                               Margin="10,5"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Answer}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Zatwierdź odpowiedzi"
                            Command="{Binding AcceptInterviewCommand}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="#6A1B9A" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"/>
                    <Button Content="Pomiń wywiad"
                            Command="{Binding SkipInterviewCommand}"
                            Padding="14,6"
                            Background="#555" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ProgressBar -->
        <ProgressBar DockPanel.Dock="Top"
                     Value="{Binding Progress}"
                     Maximum="100"
                     Height="4"
                     Background="#333"
                     Foreground="#0078D4"
                     Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>

        <!-- Dolny pasek: zapis / TFS -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D2D" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#AAAAAA"
                           FontSize="12"
                           Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="500"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Zapisz na dysk"
                            Command="{Binding SaveToDiskCommand}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"/>
                    <Button Content="Utwórz w TFS"
                            Command="{Binding CreateTfsTasksCommand}"
                            Padding="14,6"
                            Background="#795548" Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Zakładki agentów -->
        <TabControl ItemsSource="{Binding Agents}"
                    Background="#252526"
                    BorderThickness="0">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:AgentTabViewModel}">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding AgentName}"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Foreground" Value="#EF5350"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Foreground" Value="#FFA726"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:AgentTabViewModel}">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Pola agenta -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="12,8">
                            <StackPanel>
                                <!-- Loading overlay -->
                                <TextBlock Text="Generowanie..."
                                           FontSize="14"
                                           Foreground="#FFA726"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                                <!-- Dynamiczne pola -->
                                <ItemsControl ItemsSource="{Binding Fields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Label}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#BBBBBB"
                                                           Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="80"
                                                         MaxHeight="200"
                                                         Padding="8,6"
                                                         FontSize="13"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="#1E1E1E"
                                                         Foreground="#D4D4D4"
                                                         BorderBrush="#444"
                                                         CaretBrush="White"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Panel uwag i akcji -->
                        <Border Grid.Row="1" Background="#2D2D2D" Padding="12,10" BorderThickness="0,1,0,0" BorderBrush="#444">
                            <StackPanel>
                                <!-- Wiersz: uwagi + Popraw + Zatwierdź -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,6"
                                                 FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 Background="#1E1E1E"
                                                 Foreground="#D4D4D4"
                                                 BorderBrush="#555"
                                                 CaretBrush="White"/>
                                        <TextBlock Text="Uwagi do poprawki..."
                                                   Foreground="#666"
                                                   FontSize="12"
                                                   Margin="10,6"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Notes}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Generuj"
                                                Command="{Binding GenerateSingleCommand}"
                                                Padding="12,6"
                                                Margin="0,0,6,0"
                                                Background="#0078D4" Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="12"/>
                                        <Button Content="Popraw z uwagami"
                                                Command="{Binding RefineCommand}"
                                                Padding="12,6"
                                                Margin="0,0,6,0"
                                                Background="#0078D4" Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="12"/>
                                        <Button Command="{Binding ApproveCommand}"
                                                Padding="12,6"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="12">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="✓ Zatwierdź"/>
                                                    <Setter Property="Background" Value="#555"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                            <Setter Property="Content" Value="✓ Zatwierdzono"/>
                                                            <Setter Property="Background" Value="#2E7D32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Wiersz Update Docs (tylko Tech Writer) -->
                                <Grid Margin="0,8,0,0"
                                      Visibility="{Binding HasUpdateDocsSupport, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DocsUpdateStatus}"
                                               VerticalAlignment="Center"
                                               Foreground="#AAAAAA"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Button Grid.Column="1"
                                            Content="Generuj aktualizację docs"
                                            Command="{Binding GenerateDocsUpdateCommand}"
                                            Padding="12,6"
                                            Background="#4A235A" Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>
